{
  "name": "meetpin-workspace",
  "private": true,
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "android": "pnpm --filter @meetpin/mobile android",
    "build:web": "pnpm --filter @meetpin/mobile export:web",
    "dev": "pnpm --filter @meetpin/mobile start",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "ios": "pnpm --filter @meetpin/mobile ios",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "maestro:ios": "maestro test maestro/ios-smoke.yaml",
    "reset-project": "pnpm --filter @meetpin/mobile reset-project",
    "start": "pnpm --filter @meetpin/mobile start",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "pnpm --filter @meetpin/mobile exec tsc --noEmit",
    "verify": "pnpm lint && pnpm typecheck && pnpm test --runInBand && pnpm build:web",
    "web": "pnpm --filter @meetpin/mobile web"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "eslint": "^9.23.0",
    "eslint-config-expo": "^55.0.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.9",
    "prettier": "^3.5.3"
  }
}
